<form class="flexcol" autocomplete="off">
  <!-- Config Settings Configuration Tabs -->
  <nav class="sheet-tabs tabs" data-group="sections">
    <a class="item" data-tab="abilities"><i class="fa-solid fa-person"></i> {{localize "dnd5e-system-customizer.CustomizerApp.tabs.abilities.name"}}</a>
    <a class="item" data-tab="skills"><i class="fa-solid fa-person-running"></i> {{localize "dnd5e-system-customizer.CustomizerApp.tabs.skills.name"}}</a>
    <a class="item" data-tab="damageTypes"><i class="fa-solid fa-fire"></i> {{localize "dnd5e-system-customizer.CustomizerApp.tabs.damageTypes.name"}}</a>
    <a class="item" data-tab="creatureTypes"><i class="fa-solid fa-spaghetti-monster-flying"></i> {{localize "dnd5e-system-customizer.CustomizerApp.tabs.creatureTypes.name"}}</a>
    <a class="item" data-tab="languages"><i class="fa-solid fa-language"></i> {{localize "dnd5e-system-customizer.CustomizerApp.tabs.languages.name"}}</a>
  <a class="item" data-tab="hitDieTypes"><i class="fa-solid fa-dice"></i> {{localize "dnd5e-system-customizer.CustomizerApp.tabs.hitDieTypes.name"}}</a>
  <a class="item" data-tab="itemRarity"><i class="fa-regular fa-gem"></i> {{localize "dnd5e-system-customizer.CustomizerApp.tabs.itemRarity.name"}}</a>
  <a class="item" data-tab="spellLevels"><i class="fa-regular fa-book-sparkles"></i> {{localize
    "dnd5e-system-customizer.CustomizerApp.tabs.spellLevels.name"}}</a>
  <a class="item" data-tab="spellSchools"><i class="fa-solid fa-books"></i> {{localize
    "dnd5e-system-customizer.CustomizerApp.tabs.spellSchools.name"}}</a>
  <a class="item" data-tab="classFeatureTypes"><i class="fa-solid fa-sun"></i> {{localize
    "dnd5e-system-customizer.CustomizerApp.tabs.classFeatureTypes.name"}}</a>
  <a class="item" data-tab="currencies"><i class="fa-solid fa-coins"></i> {{localize
    "dnd5e-system-customizer.CustomizerApp.tabs.currencies.name"}}</a>
  
  <a class="item" data-tab="misc"><i class="fa-regular fa-cog"></i> {{localize
    "dnd5e-system-customizer.CustomizerApp.tabs.misc.name"}}</a>
  </nav>
  <section id="config-tabs" class="content">
    <hr>
    <!-- Abilities Tab -->
    <div class="tab" data-tab="abilities" data-group="sections">
      <table>
        <tr>
          <th>{{localize "dnd5e-system-customizer.CustomizerApp.tabs.abilities.abilityName"}}</th>
          <th>{{localize "dnd5e-system-customizer.CustomizerApp.tabs.abilities.abilityAbbreviation"}}</th>
          <th><i class="fas fa-eye-slash"></i></th>
          <th><i class="fas fa-trash"></i></th>
        </tr>

      {{#each ORIGINAL_CONFIG.abilities}}
      <tr data-ability-id="{{@key}}">
        <td><input type="text" readonly name="abilities.defaults.{{@key}}.name" value="{{localize label}}"></td>
        <td><input type="text" readonly name="abilities.defaults.{{@key}}.key" value="{{@key}}"></td>
        <td class="dsc-td-center"><input type="checkbox" name="abilities.defaults.{{@key}}.hide" {{dscChecked (concat "customizations.abilities.defaults." @key ".hide")}}></td>
      </tr>
      {{/each}}

      {{#each customizations.abilities.custom}}
      <tr data-ability-id="{{@key}}">
        <td><input type="text" name="abilities.custom.{{@key}}.name" value="{{this.name}}"></td>
        <td><input type="text" name="abilities.custom.{{@key}}.key" value="{{this.key}}"></td>
        <td class="dsc-td-center"><input type="checkbox" name="abilities.custom.{{@key}}.hide" {{dscChecked (concat "customizations.abilities.custom." @key ".hide")}}></td>
        <td><i class="fas fa-trash delete-ability"></i></td>
      </tr>
      {{/each}}

      </table>

      <button id="add-ability"><i class="fas fa-plus"></i> {{localize "dnd5e-system-customizer.CustomizerApp.tabs.abilities.add"}}</button>

    </div>

    <!-- Skills Tab -->
