          <th>{{localize "dnd5e-system-customizer.CustomizerApp.tabs.skills.skillAbility"}}</th>
          <th><i class="fas fa-eye-slash"></i></th>
          <th><i class="fas fa-trash"></i></th>
        </tr>
      
        {{#each ORIGINAL_CONFIG.skills}}
        <tr data-skill-id="{{@key}}">
          <td><input type="text" readonly name="skills.defaults.{{@key}}.label" value="{{localize label}}"></td>
          <td><input type="text" readonly name="skills.defaults.{{@key}}.key" value="{{@key}}"></td>
          <td><input type="text" readonly name="skills.defaults.{{@key}}.ability" value="{{ability}}"></td>
          <td class="dsc-td-center"><input type="checkbox" name="skills.defaults.{{@key}}.hide" {{dscChecked (concat "customizations.skills.defaults." @key ".hide" )}}></td>
        </tr>
        {{/each}}
      
        {{#each customizations.skills.custom}}
