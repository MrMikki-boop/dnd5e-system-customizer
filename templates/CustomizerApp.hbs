          <td><i class="fas fa-trash delete-skill"></i></td>
        </tr>
        {{/each}}
      
      </table>
      
      <button id="add-skill"><i class="fas fa-plus"></i> {{localize "dnd5e-system-customizer.CustomizerApp.tabs.skills.add"}}</button>
    </div>

