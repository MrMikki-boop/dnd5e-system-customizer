<form class="sc-form" autocomplete="off">

    {{!-- ═══════════════ ВКЛАДКИ ═══════════════ --}}
    <nav class="sc-tabs tabs" data-group="sc-main">
        <a class="item" data-tab="abilities"><i class="fas fa-fist-raised"></i> Характеристики</a>
        <a class="item" data-tab="skills"><i class="fas fa-running"></i> Навыки</a>
        <a class="item" data-tab="weapons"><i class="fas fa-sword"></i> Оружие</a>
        <a class="item" data-tab="alignments"><i class="fas fa-yin-yang"></i> Мировоззрения</a>
        <a class="item" data-tab="damage"><i class="fas fa-fire"></i> Типы урона</a>
        <a class="item" data-tab="languages"><i class="fas fa-language"></i> Языки</a>
        <a class="item" data-tab="currencies"><i class="fas fa-coins"></i> Валюта</a>
        <a class="item" data-tab="experience"><i class="fas fa-star"></i> Опыт</a>
        <a class="item" data-tab="numbers"><i class="fas fa-sliders-h"></i> Параметры</a>
    </nav>

    <div class="sc-content">

        {{!-- ═══════════ ХАРАКТЕРИСТИКИ ═══════════ --}}
        <section class="tab" data-tab="abilities" data-group="sc-main">
            <div class="sc-tab-header">
                <div class="sc-tab-title">Характеристики персонажа</div>
                <div class="sc-tab-hint">Изменяй названия стандартных характеристик или добавляй новые. Галочка скрывает характеристику от игроков, кнопка 👥 задаёт исключения.</div>
            </div>
            <table id="sc-table-abilities" class="sc-table">
                <thead>
                <tr>
                    <th style="width:80px">Ключ</th>
                    <th>Название</th>
                    <th style="width:70px">Сокращение</th>
                    <th style="width:80px" class="sc-td-center"><i class="fas fa-eye-slash"></i> <span class="sc-th-sep">|</span> <i class="fas fa-users"></i></th>
                    <th style="width:36px"></th>
                </tr>
                </thead>
                <tbody>
                {{#each abilities}}
                    <tr data-key="{{key}}" {{#if isCustom}}data-custom="true"{{/if}}>
                        <td><code class="sc-key">{{key}}</code></td>
                        <td>
                            <input type="text" name="abilities.{{key}}.label" value="{{label}}" placeholder="{{label}}">
                        </td>
                        <td><input type="text" name="abilities.{{key}}.abbr" value="{{abbr}}" style="width:56px"></td>
                        <td class="sc-td-center">
                            <div class="sc-access-group">
                                <input type="checkbox" name="abilities.{{key}}.hidden" {{#if hidden}}checked{{/if}} title="Скрыть для всех" class="sc-hide-check">
                                <button type="button" class="sc-access-btn {{#if allowedUsers}}sc-access-btn--active{{/if}}" title="Исключения (кому видно)">
                                    <i class="fas fa-users"></i>
                                </button>
                                <input type="hidden" name="abilities.{{key}}.allowedUsers" class="sc-allowed-users" value="{{allowedUsers}}">
                            </div>
                        </td>
                        <td class="sc-td-center">
                            {{#if isCustom}}<button type="button" class="sc-delete-row" title="Удалить"><i class="fas fa-trash"></i></button>{{/if}}
                        </td>
                    </tr>
                {{/each}}
                </tbody>
            </table>
            <button type="button" id="sc-add-ability" class="sc-add-btn"><i class="fas fa-plus"></i> Добавить характеристику</button>
        </section>

        {{!-- ═══════════ НАВЫКИ ═══════════ --}}
        <section class="tab" data-tab="skills" data-group="sc-main">
            <div class="sc-tab-header">
                <div class="sc-tab-title">Навыки</div>
                <div class="sc-tab-hint">Изменяй названия навыков, меняй привязанную характеристику. Список характеристик включает твои кастомные.</div>
            </div>
            <table id="sc-table-skills" class="sc-table">
                <thead>
                <tr>
                    <th style="width:70px">Ключ</th>
                    <th>Название навыка</th>
                    <th class="sc-col-skill-ability">Характеристика</th>
                    <th class="sc-col-access sc-td-center"><span class="sc-access-heading"><i class="fas fa-eye-slash"></i><i class="fas fa-users"></i></span></th>
                    <th style="width:36px"></th>
                </tr>
                </thead>
                <tbody>
                {{#each skills}}
                    <tr data-key="{{key}}" {{#if isCustom}}data-custom="true"{{/if}}>
                        <td><code class="sc-key">{{key}}</code></td>
                        <td>
                            <input type="text" name="skills.{{key}}.label" value="{{label}}" placeholder="{{label}}">
                        </td>
                        <td>
                            <select name="skills.{{key}}.ability" style="width:100px">
                                {{#each abilityOptions}}
                                    <option value="{{key}}" {{#if selected}}selected{{/if}}>{{key}}</option>
                                {{/each}}
                            </select>
                        </td>
                        <td class="sc-td-center">
                            <div class="sc-access-group">
                                <input type="checkbox" name="skills.{{key}}.hidden" {{#if hidden}}checked{{/if}} title="Скрыть для всех" class="sc-hide-check">
                                <button type="button" class="sc-access-btn {{#if allowedUsers}}sc-access-btn--active{{/if}}" title="Исключения (кому видно)">
                                    <i class="fas fa-users"></i>
                                </button>
                                <input type="hidden" name="skills.{{key}}.allowedUsers" class="sc-allowed-users" value="{{allowedUsers}}">
                            </div>
                        </td>
                        <td class="sc-td-center">
                            {{#if isCustom}}<button type="button" class="sc-delete-row" title="Удалить"><i class="fas fa-trash"></i></button>{{/if}}
                        </td>
                    </tr>
                {{/each}}
                </tbody>
            </table>
            <button type="button" id="sc-add-skill" class="sc-add-btn"><i class="fas fa-plus"></i> Добавить навык</button>
        </section>

        {{!-- ═══════════ ОРУЖИЕ ═══════════ --}}
        <section class="tab" data-tab="weapons" data-group="sc-main">
            <div class="sc-tab-header">
                <div class="sc-tab-title">Типы оружия</div>
                <div class="sc-tab-hint">Переименовывай категории оружия или добавляй свои.</div>
            </div>
            <table id="sc-table-weapons" class="sc-table">
                <thead>
                <tr>
                    <th style="width:100px">Ключ</th>
                    <th>Название</th>
                    <th style="width:80px" class="sc-td-center"><i class="fas fa-eye-slash"></i> <span class="sc-th-sep">|</span> <i class="fas fa-users"></i></th>
                    <th style="width:36px"></th>
                </tr>
                </thead>
                <tbody>
                {{#each weapons}}
                    <tr data-key="{{key}}" {{#if isCustom}}data-custom="true"{{/if}}>
                        <td><code class="sc-key">{{key}}</code></td>
                        <td><input type="text" name="weaponTypes.{{key}}.label" value="{{label}}" placeholder="{{label}}"></td>
                        <td class="sc-td-center">
                            <div class="sc-access-group">
                                <input type="checkbox" name="weaponTypes.{{key}}.hidden" {{#if hidden}}checked{{/if}} class="sc-hide-check">
                                <button type="button" class="sc-access-btn {{#if allowedUsers}}sc-access-btn--active{{/if}}" title="Исключения">
                                    <i class="fas fa-users"></i>
                                </button>
                                <input type="hidden" name="weaponTypes.{{key}}.allowedUsers" class="sc-allowed-users" value="{{allowedUsers}}">
                            </div>
                        </td>
                        <td class="sc-td-center">
                            {{#if isCustom}}<button type="button" class="sc-delete-row" title="Удалить"><i class="fas fa-trash"></i></button>{{/if}}
                        </td>
                    </tr>
                {{/each}}
                </tbody>
            </table>
            <button type="button" id="sc-add-weapon" class="sc-add-btn"><i class="fas fa-plus"></i> Добавить тип оружия</button>
        </section>

        {{!-- ═══════════ МИРОВОЗЗРЕНИЯ ═══════════ --}}
        <section class="tab" data-tab="alignments" data-group="sc-main">
            <div class="sc-tab-header">
                <div class="sc-tab-title">Мировоззрения</div>
                <div class="sc-tab-hint">Изменяй названия мировоззрений или добавляй свои для нестандартных сеттингов.</div>
            </div>
            <table id="sc-table-alignments" class="sc-table">
                <thead>
                <tr>
                    <th style="width:60px">Ключ</th>
                    <th>Название</th>
                    <th style="width:80px" class="sc-td-center"><i class="fas fa-eye-slash"></i> <span class="sc-th-sep">|</span> <i class="fas fa-users"></i></th>
                    <th style="width:36px"></th>
                </tr>
                </thead>
                <tbody>
                {{#each alignments}}
                    <tr data-key="{{key}}" {{#if isCustom}}data-custom="true"{{/if}}>
                        <td><code class="sc-key">{{key}}</code></td>
                        <td><input type="text" name="alignments.{{key}}.label" value="{{label}}" placeholder="{{label}}"></td>
                        <td class="sc-td-center">
                            <div class="sc-access-group">
                                <input type="checkbox" name="alignments.{{key}}.hidden" {{#if hidden}}checked{{/if}} class="sc-hide-check">
                                <button type="button" class="sc-access-btn {{#if allowedUsers}}sc-access-btn--active{{/if}}" title="Исключения">
                                    <i class="fas fa-users"></i>
                                </button>
                                <input type="hidden" name="alignments.{{key}}.allowedUsers" class="sc-allowed-users" value="{{allowedUsers}}">
                            </div>
                        </td>
                        <td class="sc-td-center">
                            {{#if isCustom}}<button type="button" class="sc-delete-row" title="Удалить"><i class="fas fa-trash"></i></button>{{/if}}
                        </td>
                    </tr>
                {{/each}}
                </tbody>
            </table>
            <button type="button" id="sc-add-alignment" class="sc-add-btn"><i class="fas fa-plus"></i> Добавить мировоззрение</button>
        </section>

        {{!-- ═══════════ ТИПЫ УРОНА ═══════════ --}}
        <section class="tab" data-tab="damage" data-group="sc-main">
            <div class="sc-tab-header">
                <div class="sc-tab-title">Типы урона</div>
                <div class="sc-tab-hint">Переименовывай типы урона или добавляй нестандартные. Иконка обязательна — нажми 🖼 чтобы выбрать из браузера файлов.</div>
            </div>
            <table id="sc-table-damage" class="sc-table">
                <thead>
                <tr>
                    <th class="sc-col-key">Ключ</th>
                    <th class="sc-col-name">Название</th>
                    <th class="sc-col-icon sc-td-center">Иконка</th>
                    <th class="sc-col-access sc-td-center"><span class="sc-access-heading"><i class="fas fa-eye-slash"></i><i class="fas fa-users"></i></span></th>
                    <th class="sc-col-delete"></th>
                </tr>
                </thead>
                <tbody>
                {{#each damageTypes}}
                    <tr data-key="{{key}}" {{#if isCustom}}data-custom="true"{{/if}}>
                        <td><code class="sc-key">{{key}}</code></td>
                        <td><input type="text" name="damageTypes.{{key}}.label" value="{{label}}" placeholder="{{label}}"></td>
                        <td class="sc-icon-cell">
                            <div class="sc-icon-row">
                                <img src="{{icon}}" class="sc-icon-preview" title="{{icon}}">
                                <input type="hidden" name="damageTypes.{{key}}.icon" value="{{icon}}" class="sc-icon-path">
                                <button type="button" class="sc-pick-icon" title="Выбрать иконку"><i class="fas fa-image"></i></button>
                            </div>
                        </td>
                        <td class="sc-td-center">
                            <div class="sc-access-group">
                                <input type="checkbox" name="damageTypes.{{key}}.hidden" {{#if hidden}}checked{{/if}} class="sc-hide-check">
                                <button type="button" class="sc-access-btn {{#if allowedUsers}}sc-access-btn--active{{/if}}" title="Исключения">
                                    <i class="fas fa-users"></i>
                                </button>
                                <input type="hidden" name="damageTypes.{{key}}.allowedUsers" class="sc-allowed-users" value="{{allowedUsers}}">
                            </div>
                        </td>
                        <td class="sc-td-center">
                            {{#if isCustom}}<button type="button" class="sc-delete-row" title="Удалить"><i class="fas fa-trash"></i></button>{{/if}}
                        </td>
                    </tr>
                {{/each}}
                </tbody>
            </table>
            <button type="button" id="sc-add-damage" class="sc-add-btn"><i class="fas fa-plus"></i> Добавить тип урона</button>
        </section>

        {{!-- ═══════════ ЯЗЫКИ ═══════════ --}}
        <section class="tab" data-tab="languages" data-group="sc-main">
            <div class="sc-tab-header">
                <div class="sc-tab-title">Языки</div>
                <div class="sc-tab-hint">Добавляй новые языки для своего сеттинга.</div>
            </div>
            {{#if usesLanguageGroups}}
                <div id="sc-language-sections" class="sc-language-sections">
                    {{#each languageSections}}
                        <div class="sc-language-section" data-group="{{key}}" {{#if isVirtual}}data-virtual="true"{{/if}}>
                            <div class="sc-language-section-title">
                                <code class="sc-key">{{key}}</code>
                                <input type="text" class="sc-language-group-label" name="languageGroups.{{key}}.label" value="{{label}}" placeholder="{{originalLabel}}" {{#if isVirtual}}readonly{{/if}}>
                                {{#if isCustom}}<button type="button" class="sc-delete-row" title="Удалить"><i class="fas fa-trash"></i></button>{{/if}}
                            </div>
                            <table id="sc-table-languages-{{key}}" class="sc-table sc-table-languages">
                                <thead>
                                <tr>
                                    <th style="width:100px">Ключ</th>
                                    <th>Название</th>
                                    <th style="width:80px" class="sc-td-center"><i class="fas fa-eye-slash"></i> <span class="sc-th-sep">|</span> <i class="fas fa-users"></i></th>
                                    <th style="width:36px"></th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#each languages}}
                                    <tr data-key="{{key}}" data-source-group="{{sourceGroup}}" data-path="{{path}}" {{#if isCustom}}data-custom="true"{{/if}}>
                                        <td><code class="sc-key">{{key}}</code></td>
                                        <td><input type="text" class="sc-language-label" name="languages.{{group}}.children.{{key}}.label" value="{{label}}" placeholder="{{label}}"></td>
                                        <td class="sc-td-center">
                                            <div class="sc-access-group">
                                                <input type="checkbox" name="languages.{{group}}.children.{{key}}.hidden" {{#if hidden}}checked{{/if}} class="sc-hide-check">
                                                <button type="button" class="sc-access-btn {{#if allowedUsers}}sc-access-btn--active{{/if}}" title="Исключения">
                                                    <i class="fas fa-users"></i>
                                                </button>
                                                <input type="hidden" name="languages.{{group}}.children.{{key}}.allowedUsers" class="sc-allowed-users" value="{{allowedUsers}}">
                                            </div>
                                        </td>
                                        <td class="sc-td-center">
                                            {{#if isCustom}}<button type="button" class="sc-delete-row" title="Удалить"><i class="fas fa-trash"></i></button>{{/if}}
                                        </td>
                                    </tr>
                                {{/each}}
                                </tbody>
                            </table>
                            {{#unless isVirtual}}<button type="button" class="sc-add-btn sc-add-language" data-group="{{key}}"><i class="fas fa-plus"></i> Добавить язык</button>{{/unless}}
                        </div>
                    {{/each}}
                </div>
                <button type="button" id="sc-add-language-group" class="sc-add-btn"><i class="fas fa-layer-group"></i> Добавить плашку</button>
            {{else}}
                <table id="sc-table-languages" class="sc-table">
                    <thead>
                    <tr>
                        <th style="width:100px">Ключ</th>
                        <th>Название</th>
                        <th style="width:80px" class="sc-td-center"><i class="fas fa-eye-slash"></i> <span class="sc-th-sep">|</span> <i class="fas fa-users"></i></th>
                        <th style="width:36px"></th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#each languages}}
                        <tr data-key="{{key}}" {{#if isCustom}}data-custom="true"{{/if}}>
                            <td><code class="sc-key">{{key}}</code></td>
                            <td><input type="text" name="languages.{{key}}.label" value="{{label}}" placeholder="{{label}}"></td>
                            <td class="sc-td-center">
                                <div class="sc-access-group">
                                    <input type="checkbox" name="languages.{{key}}.hidden" {{#if hidden}}checked{{/if}} class="sc-hide-check">
                                    <button type="button" class="sc-access-btn {{#if allowedUsers}}sc-access-btn--active{{/if}}" title="Исключения">
                                        <i class="fas fa-users"></i>
                                    </button>
                                    <input type="hidden" name="languages.{{key}}.allowedUsers" class="sc-allowed-users" value="{{allowedUsers}}">
                                </div>
                            </td>
                            <td class="sc-td-center">
                                {{#if isCustom}}<button type="button" class="sc-delete-row" title="Удалить"><i class="fas fa-trash"></i></button>{{/if}}
                            </td>
                        </tr>
                    {{/each}}
                    </tbody>
                </table>
                <button type="button" id="sc-add-language" class="sc-add-btn"><i class="fas fa-plus"></i> Добавить язык</button>
            {{/if}}
        </section>

        {{!-- ═══════════ ВАЛЮТА ═══════════ --}}
        <section class="tab" data-tab="currencies" data-group="sc-main">
            <div class="sc-tab-header">
                <div class="sc-tab-title">Валюты</div>
                <div class="sc-tab-hint">Переименовывай монеты — например «Золотая монета (зм)» вместо «Gold Piece (gp)».</div>
            </div>
            <table id="sc-table-currencies" class="sc-table">
                <thead>
                <tr>
                    <th style="width:60px">Ключ</th>
                    <th>Полное название</th>
                    <th style="width:80px">Сокращение</th>
                </tr>
                </thead>
                <tbody>
                {{#each currencies}}
                    <tr data-key="{{key}}">
                        <td><code class="sc-key">{{key}}</code></td>
                        <td><input type="text" name="currencies.{{key}}.label" value="{{label}}" placeholder="{{label}}"></td>
                        <td><input type="text" name="currencies.{{key}}.abbr" value="{{abbr}}" placeholder="{{abbr}}" style="width:64px"></td>
                    </tr>
                {{/each}}
                </tbody>
            </table>
        </section>

        {{!-- ═══════════ ОПЫТ ═══════════ --}}
        <section class="tab" data-tab="experience" data-group="sc-main">
            <div class="sc-tab-header">
                <div class="sc-tab-title">Опыт и уровни</div>
                <div class="sc-tab-hint">Настраивай таблицу опыта, режим вех и прогресс после максимального уровня. Значения применяются к CONFIG.DND5E после перезагрузки страницы.</div>
            </div>

            <div class="sc-experience-status sc-experience-status--noxp" data-xp-noxp-message {{#unless experience.isNoXp}}hidden{{/unless}}>
                <strong>Ручные вехи активны.</strong>
                Foundry скроет опыт в листе персонажа. Уровни нужно выдавать вручную через классы; настройки XP ниже сохранятся на будущее.
            </div>

            <div class="sc-experience-status sc-experience-status--migration" data-xp-migration-message hidden>
                При сохранении опыт персонажей будет пересчитан с сохранением прогресса внутри текущего уровня.
                <span data-xp-migration-count></span>
            </div>

            <div class="sc-experience-layout">
                <div class="sc-experience-panel">
                    <div class="sc-panel-title">Отображение опыта</div>
                    <label class="sc-field">
                        <span>Режим Foundry</span>
                        <select name="experience.levelingMode">
                            {{#each experience.levelingModeOptions}}
                                <option value="{{value}}" data-hint="{{hint}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                            {{/each}}
                        </select>
                        {{#each experience.levelingModeOptions}}
                            {{#if selected}}<em class="sc-field-help">{{hint}}</em>{{/if}}
                        {{/each}}
                    </label>

                    <label class="sc-field" data-xp-requires-tracking>
                        <span>Правило прогрессии</span>
                        <select name="experience.tableMode">
                            {{#each experience.progressionModeOptions}}
                                <option value="{{value}}" data-hint="{{hint}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                            {{/each}}
                        </select>
                        {{#each experience.progressionModeOptions}}
                            {{#if selected}}<em class="sc-field-help">{{hint}}</em>{{/if}}
                        {{/each}}
                    </label>

                    <label class="sc-field">
                        <span>Максимальный уровень</span>
                        <input type="number" name="experience.maxLevel" value="{{experience.maxLevel}}" min="1" max="100" step="1">
                    </label>

                    <label class="sc-field" data-xp-mode-field="boons" data-xp-requires-tracking>
                        <span>Интервал эпического дара</span>
                        <input type="number" name="experience.epicBoonInterval" value="{{experience.epicBoonInterval}}" min="1" step="1">
                    </label>
                </div>

                <div class="sc-experience-panel" data-xp-requires-tracking>
                    <div class="sc-panel-title">Шкала прогрессии</div>
                    <label class="sc-field" data-xp-mode-field="multiplier">
                        <span>Множитель стандарта</span>
                        <input type="number" name="experience.multiplier" value="{{experience.multiplier}}" min="0.01" step="0.01">
                    </label>

                    <label class="sc-field" data-xp-mode-field="points">
                        <span>Очков вех за уровень</span>
                        <input type="number" name="experience.pointsPerLevel" value="{{experience.pointsPerLevel}}" min="1" step="1">
                    </label>

                    <label class="sc-field" data-xp-mode-field="percent">
                        <span>Процентный шаг</span>
                        <div class="sc-input-unit">
                            <input type="number" name="experience.percentStep" value="{{experience.percentStep}}" min="1" max="100" step="1">
                            <span>%</span>
                        </div>
                    </label>

                    <div class="sc-experience-note">
                        Таблица ниже применяется напрямую только в режиме своей таблицы. В режимах множителя, очков вех и процентов она будет пересобрана автоматически после сохранения.
                        В режиме процентов Foundry всё равно хранит целое число XP: 100 пунктов = один полный уровень.
                    </div>
                </div>
            </div>

            <table id="sc-table-experience" class="sc-table" data-xp-requires-tracking data-xp-mode-field="table">
                <thead>
                <tr>
                    <th style="width:90px">Уровень</th>
                    <th>{{#if experience.isPercentMode}}Прогресс уровня{{else}}Нужно всего XP / очков{{/if}}</th>
                    <th style="width:150px">Стандарт</th>
                </tr>
                </thead>
                <tbody>
                {{#each experience.rows}}
                    <tr class="sc-xp-row" data-level="{{level}}">
                        <td><code class="sc-key">{{level}}</code></td>
                        <td>
                            <div class="sc-xp-value-wrap">
                                <input type="number" class="sc-xp-value" value="{{displayValue}}" data-cumulative="{{value}}" min="0" step="1" {{#if readonly}}readonly{{/if}}>
                                {{#if suffix}}<span>{{suffix}}</span>{{/if}}
                            </div>
                        </td>
                        <td><span class="sc-muted">{{original}}</span></td>
                    </tr>
                {{/each}}
                </tbody>
            </table>
        </section>

        {{!-- ═══════════ ПАРАМЕТРЫ ═══════════ --}}
        <section class="tab" data-tab="numbers" data-group="sc-main">
            <div class="sc-tab-header">
                <div class="sc-tab-title">Числовые параметры системы</div>
                <div class="sc-tab-hint">Базовые числа механики. Меняй только если точно понимаешь что делаешь.</div>
            </div>
            <div class="sc-numerics-grid">
                {{#each numerics}}
                    <div class="sc-numeric-card">
                        <div class="sc-numeric-label">{{label}}</div>
                        <input type="{{type}}" class="sc-numeric-field" data-key="{{key}}" data-original="{{original}}" value="{{value}}" placeholder="{{original}}" {{#if (eq type "number")}}step="1" min="0"{{/if}}>
                        <div class="sc-numeric-hint">{{hint}}</div>
                    </div>
                {{/each}}
            </div>
        </section>

    </div>{{!-- /sc-content --}}

    {{!-- ═══════════ ФУТЕР ═══════════ --}}
    <footer class="sc-footer flexrow">
        <button type="submit" class="sc-btn-save">
            <i class="fas fa-floppy-disk"></i> Сохранить изменения
        </button>
        <button type="button" id="sc-reset" class="sc-btn-reset">
            <i class="fas fa-rotate-left"></i> Сбросить всё
        </button>
    </footer>

</form>
